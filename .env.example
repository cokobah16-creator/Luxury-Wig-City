# =====================================================================
# Luxury Wig City — Environment Variables
# =====================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git (it's already in .gitignore).
# =====================================================================

# Supabase — get these from https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Flutterwave — Phase 4 (Payments)
# Get from https://dashboard.flutterwave.com → Settings → API
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxx

# WhatsApp business number (digits only, country code, no +)
VITE_WHATSAPP_NUMBER=2348000000000

# Optional — Phase 5 AI try-on / wig health check
# VITE_REPLICATE_API_TOKEN=
# VITE_OPENAI_API_KEY=
